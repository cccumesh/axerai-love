# ─── Local dev (.env) — direct browser calls ───
VITE_GEMINI_API_KEY=your_google_ai_studio_api_key_here
VITE_ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
VITE_ELEVENLABS_VOICE_ID=your_elevenlabs_voice_id_here
#
# ─── Netlify production (secure proxy — NOT in .env file) ───
# Set in Netlify dashboard only (Functions + Runtime scope):
#   GEMINI_API_KEY=same_as_VITE_GEMINI_API_KEY_above
#   ELEVENLABS_API_KEY=same_as_VITE_ELEVENLABS_API_KEY_above
#   ELEVENLABS_VOICE_ID=same_as_VITE_ELEVENLABS_VOICE_ID_above
# Do NOT set VITE_GEMINI_API_KEY or VITE_ELEVENLABS_API_KEY on Netlify — they embed in the public bundle.
#
# Get a free Gemini key: https://aistudio.google.com/apikey
#
# Supabase ledger (public anon key is OK in frontend)
VITE_DASHBOARD_PATH=axerai-insights-7k2m
VITE_DASHBOARD_PASSWORD=your_strong_dashboard_password
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_or_publishable_key_here
